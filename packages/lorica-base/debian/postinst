#!/bin/sh
set -e

case "$1" in
  configure)
    # --- io_uring restriction (kernel version dependent) ---
    # io_uring has been a prolific CVE source. Google disabled it in prod.
    # kernel >= 6.6: io_uring_disabled sysctl available
    # kernel <  6.6 but >= 5.13: io_uring_group available
    # kernel <  5.13: no io_uring sysctl, skip
    IOURING_CONF="/etc/sysctl.d/91-lorica-io-uring.conf"
    mkdir -p /etc/sysctl.d
    KVER=$(uname -r | cut -d. -f1-2)
    KMAJOR=$(echo "$KVER" | cut -d. -f1)
    KMINOR=$(echo "$KVER" | cut -d. -f2)

    cat > "$IOURING_CONF" << 'HEADER'
# Lorica Linux -- io_uring restriction (auto-generated by lorica-base postinst)
# Regenerate by reinstalling: apt install --reinstall lorica-base
HEADER

    if [ "$KMAJOR" -gt 6 ] || { [ "$KMAJOR" -eq 6 ] && [ "$KMINOR" -ge 6 ]; }; then
      echo "# Kernel >= 6.6: using io_uring_disabled=1 (unprivileged disabled)" >> "$IOURING_CONF"
      echo "kernel.io_uring_disabled=1" >> "$IOURING_CONF"
    elif [ "$KMAJOR" -gt 5 ] || { [ "$KMAJOR" -eq 5 ] && [ "$KMINOR" -ge 13 ]; }; then
      echo "# Kernel >= 5.13, < 6.6: using io_uring_group=-1 (root only)" >> "$IOURING_CONF"
      echo "kernel.io_uring_group=-1" >> "$IOURING_CONF"
    else
      echo "# Kernel < 5.13: io_uring sysctl not available, skipping" >> "$IOURING_CONF"
    fi

    # --- Apply sysctl settings ---
    sysctl --system > /dev/null 2>&1 || true

    # --- Update GRUB if installed ---
    if command -v update-grub > /dev/null 2>&1; then
      update-grub 2> /dev/null || true
    fi

    echo "lorica-base: Hardening applied. Reboot recommended for boot parameters."
    ;;
esac

#DEBHELPER#
