# Lorica Linux -- Audit Rules for Compliance (lorica-base)
# /etc/audit/rules.d/lorica-compliance.rules
#
# Source of truth: docs/hardening-decisions.md (Section 4)
# Profile: BASE
#
# Mapped to: CIS Debian 12 Benchmark, PCI-DSS v3.2.1/v4.0, SOC 2
# All syscall rules include b64 and b32 variants (32-bit syscall bypass prevention).
#
# arm64 compatibility: syscall rules use *at variants (fchmodat, fchownat,
# unlinkat, renameat) instead of legacy syscalls (chmod, chown, unlink, rename)
# which do not exist in the arm64 b64 syscall table. glibc wraps the legacy
# libc calls to *at variants internally, so coverage is identical.
#
# WARNING: -e 2 at the end makes rules immutable until reboot.

# Buffer size -- large enough for busy servers
-b 8192

# Failure mode -- log to syslog on buffer overflow (don't panic)
-f 1

# =============================================================================
# 4.1 Identity and Access Changes
# CIS 4.1.4 | PCI-DSS 10.2.5 | SOC 2 CC6.1
# =============================================================================
-w /etc/passwd -p wa -k identity
-w /etc/group -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/security/opasswd -p wa -k identity

# =============================================================================
# 4.2 Privilege Escalation
# CIS 4.1.5 | PCI-DSS 10.2.2 | SOC 2 CC6.1
# =============================================================================
-w /etc/sudoers -p wa -k scope
-w /etc/sudoers.d -p wa -k scope

# =============================================================================
# 4.3 Privileged Command Execution
# CIS 4.1.11 | PCI-DSS 10.2.2 | SOC 2 CC7.1
# =============================================================================
-a always,exit -F path=/usr/bin/passwd -F perm=x -F auid>=1000 -F auid!=-1 -k privileged
-a always,exit -F path=/usr/bin/sudo -F perm=x -F auid>=1000 -F auid!=-1 -k privileged
-a always,exit -F path=/usr/bin/su -F perm=x -F auid>=1000 -F auid!=-1 -k privileged
-a always,exit -F path=/usr/bin/chsh -F perm=x -F auid>=1000 -F auid!=-1 -k privileged
-a always,exit -F path=/usr/bin/newgrp -F perm=x -F auid>=1000 -F auid!=-1 -k privileged
-a always,exit -F path=/usr/sbin/usermod -F perm=x -F auid>=1000 -F auid!=-1 -k privileged
-a always,exit -F path=/usr/sbin/groupmod -F perm=x -F auid>=1000 -F auid!=-1 -k privileged
-a always,exit -F path=/usr/sbin/useradd -F perm=x -F auid>=1000 -F auid!=-1 -k privileged
-a always,exit -F path=/usr/sbin/userdel -F perm=x -F auid>=1000 -F auid!=-1 -k privileged
-a always,exit -F path=/usr/sbin/groupadd -F perm=x -F auid>=1000 -F auid!=-1 -k privileged
-a always,exit -F path=/usr/sbin/groupdel -F perm=x -F auid>=1000 -F auid!=-1 -k privileged

# =============================================================================
# 4.4 Login and Session Events
# CIS 4.1.7 | PCI-DSS 10.2.1/10.2.4 | SOC 2 CC7.1
# =============================================================================
-w /var/log/faillog -p wa -k logins
-w /var/log/lastlog -p wa -k logins
-w /var/run/utmp -p wa -k session
-w /var/log/wtmp -p wa -k logins
-w /var/log/btmp -p wa -k logins

# =============================================================================
# 4.5 Time Changes
# CIS 4.1.3 | PCI-DSS 10.4 | SOC 2 CC7.1
# =============================================================================
-a always,exit -F arch=b64 -S adjtimex -S settimeofday -k time-change
-a always,exit -F arch=b32 -S adjtimex -S settimeofday -k time-change
-a always,exit -F arch=b64 -S clock_settime -k time-change
-a always,exit -F arch=b32 -S clock_settime -k time-change
-w /etc/localtime -p wa -k time-change

# =============================================================================
# 4.6 Network Configuration Changes
# CIS 4.1.6 | PCI-DSS 10.2.7 | SOC 2 CC7.1
# =============================================================================
-w /etc/hosts -p wa -k network_modifications
-w /etc/hostname -p wa -k network_modifications
-w /etc/network -p wa -k network_modifications
-w /etc/issue -p wa -k system-locale
-w /etc/issue.net -p wa -k system-locale

# =============================================================================
# 4.7 Kernel Module Loading
# CIS 4.1.16 | PCI-DSS 10.2.7 | SOC 2 CC7.1
# =============================================================================
-a always,exit -F arch=b64 -S init_module -S finit_module -S delete_module -F auid!=-1 -k modules
-a always,exit -F arch=b32 -S init_module -S finit_module -S delete_module -F auid!=-1 -k modules
-w /sbin/modprobe -p x -k modules
-w /etc/modprobe.d -p wa -k modprobe

# =============================================================================
# 4.8 Mount Operations
# CIS 4.1.12 | PCI-DSS 10.2.7 | SOC 2 CC7.1
# =============================================================================
-a always,exit -F arch=b64 -S mount -S umount2 -F auid!=-1 -k mount
-a always,exit -F arch=b32 -S mount -S umount2 -F auid!=-1 -k mount

# =============================================================================
# 4.9 File Permission Changes
# CIS 4.1.9 | PCI-DSS 10.2.7 | SOC 2 CC7.1
# =============================================================================
-a always,exit -F arch=b64 -S fchmodat -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S chmod -S fchmod -S fchmodat -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S fchownat -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S chown -S fchown -S fchownat -S lchown -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S setxattr -S lsetxattr -S fsetxattr -S removexattr -S lremovexattr -S fremovexattr -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S setxattr -S lsetxattr -S fsetxattr -S removexattr -S lremovexattr -S fremovexattr -F auid>=1000 -F auid!=-1 -k perm_mod

# =============================================================================
# 4.10 File Deletion by Users
# CIS 4.1.13 | PCI-DSS 10.2.7 | SOC 2 CC7.1
# =============================================================================
-a always,exit -F arch=b64 -S unlinkat -S renameat -F auid>=1000 -F auid!=-1 -k delete
-a always,exit -F arch=b32 -S unlink -S unlinkat -S rename -S renameat -F auid>=1000 -F auid!=-1 -k delete

# =============================================================================
# 4.11 Execution from World-Writable Directories (Lorica original)
# PCI-DSS 10.2.7 | SOC 2 CC7.1
# Detects attacker binary drops in /tmp and /var/tmp
# =============================================================================
-a always,exit -F arch=b64 -S execve -F dir=/tmp -k tmp_exec
-a always,exit -F arch=b32 -S execve -F dir=/tmp -k tmp_exec
-a always,exit -F arch=b64 -S execve -F dir=/var/tmp -k tmp_exec
-a always,exit -F arch=b32 -S execve -F dir=/var/tmp -k tmp_exec

# =============================================================================
# 4.12 Scheduled Tasks and SSH
# CIS 4.1.15 | PCI-DSS 10.2.7 | SOC 2 CC7.1
# =============================================================================
-w /etc/cron.allow -p wa -k cron
-w /etc/cron.deny -p wa -k cron
-w /etc/cron.d -p wa -k cron
-w /etc/crontab -p wa -k cron
-w /etc/at.allow -p wa -k cron
-w /etc/at.deny -p wa -k cron
-w /etc/ssh/sshd_config -p wa -k sshd

# =============================================================================
# 4.13 Audit Configuration Immutability
# CIS 4.1.17 | PCI-DSS 10.5 | SOC 2 CC7.1
# MUST be the last rule. Prevents attacker from disabling audit after root compromise.
# =============================================================================
-e 2
