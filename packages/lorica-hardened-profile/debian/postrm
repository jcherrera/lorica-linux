#!/bin/sh
set -e

case "$1" in
  remove|purge)
    # Reload sysctl to revert to lorica-base defaults
    sysctl --system > /dev/null 2>&1 || true

    # Regenerate GRUB config without hardened params
    if command -v update-grub > /dev/null 2>&1; then
      update-grub 2> /dev/null || true
    fi
    ;;
esac

#DEBHELPER#
